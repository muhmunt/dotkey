# ── Docker Compose ─────────────────────────────────────────────────────────────
# Postgres password used by both the db service and the api connection string
DB_PASSWORD=change-me

# URL the browser uses to reach the API — set to your public domain in production
# e.g. https://api.yourdomain.com
API_URL=http://localhost:8080

# Comma-separated origins allowed to call the API (must include your dashboard URL)
ALLOWED_ORIGINS=http://localhost:3000

# ── Backend ────────────────────────────────────────────────────────────────────
# Only needed when running the backend directly (not via docker-compose)
DATABASE_URL=postgres://dotkey:change-me@localhost:5432/dotkey?sslmode=disable

JWT_SECRET=change-me-use-openssl-rand-base64-32
ENCRYPTION_KEY=change-me-exactly-32-bytes-here!!
PORT=8080
