# ── Docker Compose ─────────────────────────────────────────────────────────────
# Postgres password used by both the db service and the api connection string
DB_PASSWORD=change-me

# URL the browser uses to reach the API — set to your public domain in production
# e.g. https://api.yourdomain.com
API_URL=http://localhost:8080

# Comma-separated origins allowed to call the API (must include your dashboard URL)
ALLOWED_ORIGINS=http://localhost:3000

# ── Backend ────────────────────────────────────────────────────────────────────
# Only needed when running the backend directly (not via docker-compose)
DATABASE_URL=postgres://dotkey:change-me@localhost:5432/dotkey?sslmode=disable

# Generate strong values with:
#   JWT_SECRET:     openssl rand -hex 32
#   ENCRYPTION_KEY: openssl rand -hex 16   (must be exactly 32 ASCII chars)
JWT_SECRET=change-me-use-openssl-rand-hex-32
ENCRYPTION_KEY=change-me-exactly-32-bytes!!
PORT=8080

# ── .env encryption (optional but recommended for production) ─────────────────
# Generate a master key:  go run ./tools/envenc keygen
# Encrypt sensitive values: DOTKEY_MASTER_KEY=<key> go run ./tools/envenc encrypt .env
# At server startup, set DOTKEY_MASTER_KEY so the server decrypts values automatically.
# The key itself should come from a Docker secret, systemd credential, or shell env —
# never store it in .env.
#
# Example encrypted .env after running dotkey-enc encrypt:
#   JWT_SECRET=encrypted:v1:<nonce>:<ciphertext>
#   ENCRYPTION_KEY=encrypted:v1:<nonce>:<ciphertext>
#   DATABASE_URL=encrypted:v1:<nonce>:<ciphertext>
#   PORT=8080                          ← non-sensitive values stay plaintext
#
# DOTKEY_MASTER_KEY is intentionally NOT stored in this file.
