# macOS Homebrew Postgres: use your OS username, often no password
# DATABASE_URL=postgres://YOUR_OS_USER@localhost:5432/envx?sslmode=disable
DATABASE_URL=postgres://postgres:password@localhost:5432/envx?sslmode=disable
JWT_SECRET=your-super-secret-jwt-key-change-in-production
ENCRYPTION_KEY=your-32-byte-encryption-key-here!!
PORT=8080
